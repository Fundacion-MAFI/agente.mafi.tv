# =============================================================================
# Film Agent / Agente Fílmico – Environment Variables
# =============================================================================
# Copy to .env.local (or .env) and fill in the values.
# See README.md for setup instructions.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Postgres)
# -----------------------------------------------------------------------------
# Neon Serverless Postgres connection string. Required for chats, users,
# artifacts, and the MAFI shots corpus (Archivo mode).
# Get from: https://neon.tech or your Postgres provider.
POSTGRES_URL=postgres://user:password@host/database?sslmode=require

# Optional. Use for migrations and schema changes; Neon recommends the
# non-pooling URL when running Drizzle migrations. Falls back to POSTGRES_URL.
# POSTGRES_URL_NON_POOLING=postgres://user:password@host/database?sslmode=require

# -----------------------------------------------------------------------------
# Auth (Auth.js / NextAuth)
# -----------------------------------------------------------------------------
# Secret for signing cookies and JWTs. Generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-here

# Optional. Base URL of the app. Only needed when auth callbacks fail to detect
# the correct URL (e.g. custom domain, reverse proxy).
# AUTH_URL=https://your-domain.com

# -----------------------------------------------------------------------------
# AI / LLM (Vercel AI Gateway)
# -----------------------------------------------------------------------------
# API key for the Vercel AI Gateway. Used for chat, embeddings, Archivo mode.
# Create in Vercel Dashboard → AI → Gateway. Required for AI features.
AI_GATEWAY_API_KEY=your-ai-gateway-api-key

# Optional. Override the gateway for Archivo mode only. Set both or neither.
# Useful for pointing Archivo at a different provider (e.g. Anthropic, Fireworks).
# AI_GATEWAY_FILM_AGENT_BASE_URL=https://api.example.com/v1
# AI_GATEWAY_FILM_AGENT_API_KEY=your-provider-api-key

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
# Optional. Vercel Blob token for file uploads (e.g. image attachments).
# Create in Vercel Dashboard → Storage → Blob. Omitted = uploads disabled.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# -----------------------------------------------------------------------------
# Ingestion Throttling
# -----------------------------------------------------------------------------
# Optional. When set (1, true, yes), adds a delay between embedding API calls
# during `pnpm ingest:mafi` to avoid Vercel AI Gateway rate limits on free tier.
# INGEST_THROTTLE_EMBEDDINGS=true

# Optional. Delay in ms between embedding calls when throttling is enabled.
# Default: 2000. Increase if you still hit rate limits.
# INGEST_THROTTLE_DELAY_MS=3000

# -----------------------------------------------------------------------------
# Admin
# -----------------------------------------------------------------------------
# Comma-separated emails allowed to access /admin. Required for admin UI.
# ADMIN_EMAILS=admin@example.com

# API key for admin API (scripts, automation). Header: Authorization: Bearer <key>
# or X-Admin-API-Key. Generate with: openssl rand -hex 32
# ADMIN_API_KEY=your-admin-api-key

# -----------------------------------------------------------------------------
# GitHub (Admin shot sync)
# -----------------------------------------------------------------------------
# Required for admin to sync shot edits to the repo. Create a token with repo scope.
# GITHUB_TOKEN=ghp_xxx
# GITHUB_REPO=owner/repo

# -----------------------------------------------------------------------------
# Resumable Streams
# -----------------------------------------------------------------------------
# Optional. Redis URL for resumable chat streams (reconnect after refresh).
# Upstash Redis recommended. Omitted = streams work but are not resumable.
# REDIS_URL=redis://default:xxx@xxx.upstash.io:6379
